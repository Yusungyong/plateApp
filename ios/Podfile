# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '16.0'
prepare_react_native_project!

install! 'cocoapods',
  :warn_for_multiple_pod_sources => false,
  :warn_for_unused_master_specs_repo => false

# 새 아키텍처 강제 비활성(중복 코드젠 예방)
ENV['RCT_NEW_ARCH_ENABLED'] = '0'

# 필요 시 동적/정적 전환 (기본: 정적)
linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

# 🔹 코드젠 산출물이 중복되는 경우가 있어, pod 설치 직전 항상 정리
pre_install do |installer|
  generated = File.join(Pod::Config.instance.installation_root.to_path, 'build', 'generated', 'ios')
  if File.directory?(generated)
    Pod::UI.puts "Cleaning stale codegen: #{generated}".yellow
    FileUtils.rm_rf(generated)
  end
end

target 'PlateApp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :hermes_enabled => false
  )

  # ===== Firebase / Google =====
  # Swift Pod(FirebaseCoreInternal) → GoogleUtilities 모듈맵 필요
  pod 'Firebase/Messaging'
  pod 'GoogleUtilities',       :modular_headers => true
  pod 'FirebaseCoreInternal',  :modular_headers => true  # 명시적으로 추가(트랜지티브여도 안전)

  # ===== Maps =====
  pod 'GoogleMaps'
  pod 'Google-Maps-iOS-Utils'
  pod 'react-native-maps', :path => '../node_modules/react-native-maps'
end

post_install do |installer|
  react_native_post_install(
    installer,
    Pod::Config.instance.installation_root.join('..').to_path,
    :mac_catalyst_enabled => false
  )

  # 모든 타깃에 iOS 최소버전 강제
  installer.generated_projects.each do |project|
    project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      end
    end
  end
end
