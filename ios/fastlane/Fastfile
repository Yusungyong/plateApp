default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do

    puts "🔍 현재 디렉토리: #{Dir.pwd}"
    sh "ls -al"

    # GitHub Secrets에서 환경변수로 받은 키 정보를 파일로 저장
    File.write("./AuthKey.p8", ENV["APP_STORE_CONNECT_API_KEY_KEY_CONTENT"])

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: "./AuthKey.p8"
    )

    match(
      type: "appstore",
      readonly: false,
      git_url: "https://github.com/Yusungyong/plateApp.git",
      git_basic_authorization: ENV["GIT_AUTHORIZATION"] # 이건 3단계에서 다룰게
    )

    build_app(
      workspace: "PlateApp.xcworkspace",
      scheme: "PlateApp",
      export_method: "app-store"
    )

    upload_to_testflight(api_key: api_key)
  end
end
