default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_KEY_ID'],         # ✅ Secrets 이름에 맞춤
      issuer_id: ENV['APP_STORE_CONNECT_API_KEY_ISSUER_ID'],   # ✅ 맞춤
      key_filepath: "./fastlane/AuthKey.p8",                   # ✅ Workflow에서 생성됨
      duration: 1200,
      in_house: false
    )

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      git_url: "https://github.com/Yusungyong/plate-certificates.git",
      branch: "main",
      clone_branch_directly: true
    )

    build_app(
      scheme: "PlateApp",
      export_method: "app-store",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key
    )
  end
end
