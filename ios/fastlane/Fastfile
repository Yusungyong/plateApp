default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :release do
    # App Store Connect API 키 불러오기
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_API_ISSUER_ID'],
      key_filepath: "./fastlane/AuthKey.p8", # GitHub Actions에서 생성됨
      duration: 1200,
      in_house: false
    )

    # 인증서 및 프로비저닝 프로파일 가져오기
    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      git_url: "https://github.com/Yusungyong/plate-certificates.git",
      branch: "main",
      clone_branch_directly: true
    )

    # 앱 빌드
    build_app(
      scheme: "PlateApp",           # ← 실제 Xcode의 Scheme 이름
      export_method: "app-store",   # TestFlight 배포를 위한 export 방식
      clean: true
    )

    # TestFlight 업로드
    upload_to_testflight(
      api_key: api_key
    )
  end
end
