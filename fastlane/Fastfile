# …위 생략…

lane :release do
  api_key =
    if ENV["ASC_KEY_P8"] # CI용(시크릿)
      app_store_connect_api_key(
        key_id: ENV.fetch("ASC_KEY_ID"),
        issuer_id: ENV.fetch("ASC_ISSUER_ID"),
        key_content: ENV.fetch("ASC_KEY_P8"),
        duration: 1200,
        in_house: false
      )
    else # 로컬용(파일)
      app_store_connect_api_key(
        key_id: ENV.fetch("ASC_KEY_ID"),
        issuer_id: ENV.fetch("ASC_ISSUER_ID"),
        key_filepath: "./AuthKey_#{ENV.fetch('ASC_KEY_ID')}.p8",
        duration: 1200,
        in_house: false
      )
    end

  match(
    type: "appstore",
    api_key: api_key,
    app_identifier: ["kr.yuseongyong.plateApp"],
    git_url: "https://github.com/Yusungyong/plate-certificates.git",
    git_basic_authorization: ENV.fetch("GIT_AUTHORIZATION"),
    git_branch: "main",                 # ← 바꾼 브랜치
    clone_branch_directly: true,
    storage_mode: "git",
    readonly: true
  )

  increment_build_number(xcodeproj: "ios/PlateApp.xcodeproj")

  build_app(
    workspace: "ios/PlateApp.xcworkspace",
    scheme: "PlateApp",
    configuration: "Release",
    export_method: "app-store",
    clean: true
  )

  upload_to_testflight(
    api_key: api_key,
    changelog: ENV["TF_CHANGELOG"] || "Bug fixes & performance improvements",
    skip_waiting_for_build_processing: true,
    # 필요시 내부 테스터 그룹 자동 배포:
    # groups: ["Internal Testers"]
  )
end
