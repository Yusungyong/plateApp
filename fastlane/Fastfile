default_platform(:ios)

platform :ios do
  desc "Build & upload to TestFlight (no match)"
  lane :release do
    id = ENV.fetch("ASC_KEY_ID")
    issuer = ENV.fetch("ASC_ISSUER_ID")
    keyfile = File.expand_path("./AuthKey_#{id}.p8", __dir__)

    api_key =
      if ENV["ASC_KEY_P8"] && !ENV["ASC_KEY_P8"].strip.empty?
        UI.message("Using ASC_KEY_P8 from env var")
        app_store_connect_api_key(
          key_id: id, issuer_id: issuer,
          key_content: ENV["ASC_KEY_P8"],
          duration: 1200, in_house: false
        )
      elsif File.exist?(keyfile)
        UI.message("Using local p8 file: #{keyfile}")
        app_store_connect_api_key(
          key_id: id, issuer_id: issuer,
          key_filepath: keyfile,
          duration: 1200, in_house: false
        )
      else
        UI.user_error!("No ASC key provided (ASC_KEY_P8 env or #{keyfile})")
      end

    # 👉 프로파일/수동서명 강제 주입 ❌ 전부 제거
    #    - CODE_SIGN_STYLE=Manual, PROVISIONING_PROFILE_SPECIFIER, CODE_SIGN_IDENTITY 다 제거
    #    - disable_xcpretty 도 경고나니 제거하고 formatter 사용

    match(
      type: "appstore",
      app_identifier: "kr.yuseongyong.plateApp",
      readonly: true,
      git_url: "git@github.com:Yusungyong/plate-certificates.git" # ← SSH
      # clone_branch_directly: true  # ← 첫 실행엔 제거
      # git_branch: "master"         # 기본이면 생략 가능
    )

    build_app(
      workspace: "ios/PlateApp.xcworkspace",
      scheme: "PlateApp",
      configuration: "Release",
      export_method: "app-store",
      xcodebuild_formatter: "xcbeautify",
      # 최소한의 xcargs 만 (팀 ID 정도)
      xcargs: "DEVELOPMENT_TEAM=VM93Q33652",

      # export_options 에서 manual / provisioningProfiles 맵핑도 제거
      export_options: {
        method: "app-store"
      },

      output_directory: ".",
      output_name: "PlateApp"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["TF_CHANGELOG"] || "CI auto build"
    )
  end
end
