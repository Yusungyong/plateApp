default_platform(:ios)

platform :ios do
  desc "Build & upload to TestFlight (no match)"
  lane :release do
    id = ENV.fetch("ASC_KEY_ID")
    issuer = ENV.fetch("ASC_ISSUER_ID")
    keyfile = File.expand_path("./AuthKey_#{id}.p8", __dir__)

    api_key =
      if ENV["ASC_KEY_P8"] && !ENV["ASC_KEY_P8"].strip.empty?
        UI.message("Using ASC_KEY_P8 from env var")
        app_store_connect_api_key(
          key_id: id, issuer_id: issuer,
          key_content: ENV["ASC_KEY_P8"],
          duration: 1200, in_house: false
        )
      elsif File.exist?(keyfile)
        UI.message("Using local p8 file: #{keyfile}")
        app_store_connect_api_key(
          key_id: id, issuer_id: issuer,
          key_filepath: keyfile,
          duration: 1200, in_house: false
        )
      else
        UI.user_error!("No ASC key provided (ASC_KEY_P8 env or #{keyfile})")
      end

    # 워크플로에서 추출해 준 값 사용 (없으면 안전한 기본값)
    profile_uuid = ENV["PROFILE_UUID"] || ""
    profile_name = ENV["PROFILE_NAME"] || "AppStore #{ENV['PRODUCT_BUNDLE_IDENTIFIER'] || 'kr.yuseongyong.plateApp'}"

    build_app(
      workspace: "ios/PlateApp.xcworkspace",
      scheme: "PlateApp",
      configuration: "Release",
      export_method: "app-store",
      disable_xcpretty: true,            # 포매터 완전 비활성화
      # clean: true,                      # 필요시만 켜기
      xcargs: %(
        DEVELOPMENT_TEAM=VM93Q33652
        CODE_SIGN_STYLE=Manual
        PROVISIONING_PROFILE_SPECIFIER=#{profile_uuid}
        CODE_SIGN_IDENTITY="Apple Distribution"
      ),
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          # 번들아이디 => 프로파일 "이름" (ExportOptions는 이름 필요)
          "kr.yuseongyong.plateApp" => profile_name
        }
      },
      output_directory: ".",
      output_name: "PlateApp"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["TF_CHANGELOG"] || "CI auto build"
    )
  end
end
