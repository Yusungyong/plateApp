default_platform(:ios)

platform :ios do
  # ── (선택) ASC 연결 진단 ───────────────────────────────────────
  desc "Test App Store Connect API connection (no match)"
  lane :asc_ping do
    id = ENV.fetch("ASC_KEY_ID")
    issuer = ENV.fetch("ASC_ISSUER_ID")
    keyfile = File.expand_path("./AuthKey_#{id}.p8", __dir__) # fastlane 작업 디렉토리 기준 절대경로

    token =
      if File.exist?(keyfile)
        UI.message("Using local p8 file: #{keyfile}")
        Spaceship::ConnectAPI::Token.create(
          key_id: id, issuer_id: issuer, key: File.read(keyfile),
          duration: 1200, in_house: false
        )
      else
        UI.message("Using ASC_KEY_P8 from env var")
        Spaceship::ConnectAPI::Token.create(
          key_id: id, issuer_id: issuer, key: ENV.fetch("ASC_KEY_P8"),
          duration: 1200, in_house: false
        )
      end

    Spaceship::ConnectAPI.token = token
    apps = Spaceship::ConnectAPI::App.all
    UI.message("ASC app count: #{apps.size}")
  end

  # ── TestFlight 빌드/업로드 (match 없음) ─────────────────────────
  desc "Build & upload to TestFlight (no match)"
  lane :release do
    id = ENV.fetch("ASC_KEY_ID")
    issuer = ENV.fetch("ASC_ISSUER_ID")
    keyfile = File.expand_path("./AuthKey_#{id}.p8", __dir__) # fastlane 작업 디렉토리 기준 절대경로

    api_key =
      if File.exist?(keyfile)
        UI.message("Using local p8 file: #{keyfile}")
        app_store_connect_api_key(
          key_id: id, issuer_id: issuer, key_filepath: keyfile,
          duration: 1200, in_house: false
        )
      else
        UI.message("Using ASC_KEY_P8 from env var")
        app_store_connect_api_key(
          key_id: id, issuer_id: issuer, key_content: ENV.fetch("ASC_KEY_P8"),
          duration: 1200, in_house: false
        )
      end

    # 필요하면 빌드 넘버 자동 증가(옵션)
    # increment_build_number(xcodeproj: "ios/PlateApp.xcodeproj")

    build_app(
      workspace: "ios/PlateApp.xcworkspace",
      scheme: "PlateApp",
      configuration: "Release",
      export_method: "app-store",
      clean: true
      # export_options: {
      #   provisioningProfiles: {
      #     "kr.yuseongyong.plateApp" => "PlateApp AppStore" # 프로비저닝 프로파일 이름(필요 시 명시)
      #   }
      # }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["TF_CHANGELOG"] || "CI auto build"
      # groups: ["Internal Testers"] # 내부 테스터 자동 배포 원하면 사용
    )
  end
end
