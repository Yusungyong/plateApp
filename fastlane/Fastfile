default_platform(:ios)

platform :ios do
  # App Store Connect API 연결 테스트
  desc "Test App Store Connect API connection"
  lane :asc_ping do
    id = ENV.fetch("ASC_KEY_ID")
    issuer = ENV.fetch("ASC_ISSUER_ID")
    keyfile = File.expand_path("./AuthKey_#{id}.p8", __dir__) # ✅ 절대경로

    token =
      if File.exist?(keyfile)
        UI.message("Using local p8 file: #{keyfile}")
        Spaceship::ConnectAPI::Token.create(
          key_id: id,
          issuer_id: issuer,
          key: File.read(keyfile),
          duration: 1200,
          in_house: false
        )
      else
        UI.message("Using ASC_KEY_P8 from env var")
        Spaceship::ConnectAPI::Token.create(
          key_id: id,
          issuer_id: issuer,
          key: ENV.fetch("ASC_KEY_P8"),
          duration: 1200,
          in_house: false
        )
      end

    Spaceship::ConnectAPI.token = token
    apps = Spaceship::ConnectAPI::App.all
    UI.message("ASC app count: #{apps.size}")
  end

  # TestFlight 업로드
  desc "Build & upload to TestFlight"
  lane :release do
    id = ENV.fetch("ASC_KEY_ID")
    issuer = ENV.fetch("ASC_ISSUER_ID")
    keyfile = File.expand_path("./AuthKey_#{id}.p8", __dir__) # ✅ 절대경로

    api_key =
      if File.exist?(keyfile)
        UI.message("Using local p8 file: #{keyfile}")
        app_store_connect_api_key(
          key_id: id,
          issuer_id: issuer,
          key_filepath: keyfile,
          duration: 1200,
          in_house: false
        )
      else
        UI.message("Using ASC_KEY_P8 from env var")
        app_store_connect_api_key(
          key_id: id,
          issuer_id: issuer,
          key_content: ENV.fetch("ASC_KEY_P8"),
          duration: 1200,
          in_house: false
        )
      end

    match(
      type: "appstore",
      api_key: api_key,
      app_identifier: ["kr.yuseongyong.plateApp"],
      git_url: "https://github.com/Yusungyong/plate-certificates.git",
      git_basic_authorization: ENV["GIT_AUTHORIZATION"],
      git_branch: "main",
      clone_branch_directly: true,
      storage_mode: "git",
      readonly: false
    )

    build_app(
      scheme: "PlateApp",
      workspace: "ios/PlateApp.xcworkspace",
      export_method: "app-store",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["TF_CHANGELOG"]
    )
  end
end
