default_platform(:ios)

platform :ios do
  # ASC 연결 테스트(네 것 유지)
  desc "Test App Store Connect API connection (no match)"
  lane :asc_ping do
    id = ENV.fetch("ASC_KEY_ID")
    issuer = ENV.fetch("ASC_ISSUER_ID")
    keyfile = File.expand_path("./AuthKey_#{id}.p8", __dir__)

    token =
      if ENV["ASC_KEY_P8"] && !ENV["ASC_KEY_P8"].strip.empty?
        UI.message("Using ASC_KEY_P8 from env var")
        Spaceship::ConnectAPI::Token.create(
          key_id: id, issuer_id: issuer, key: ENV["ASC_KEY_P8"],
          duration: 1200, in_house: false
        )
      elsif File.exist?(keyfile)
        UI.message("Using local p8 file: #{keyfile}")
        Spaceship::ConnectAPI::Token.create(
          key_id: id, issuer_id: issuer, key: File.read(keyfile),
          duration: 1200, in_house: false
        )
      else
        UI.user_error!("No ASC key provided (ASC_KEY_P8 env or #{keyfile})")
      end

    Spaceship::ConnectAPI.token = token
    apps = Spaceship::ConnectAPI::App.all
    UI.message("ASC app count: #{apps.size}")
  end

  # TestFlight 빌드/업로드(네 것 유지)
  desc "Build & upload to TestFlight (no match)"
  lane :release do
    id = ENV.fetch("ASC_KEY_ID")
    issuer = ENV.fetch("ASC_ISSUER_ID")
    keyfile = File.expand_path("./AuthKey_#{id}.p8", __dir__)

    api_key =
      if ENV["ASC_KEY_P8"] && !ENV["ASC_KEY_P8"].strip.empty?
        UI.message("Using ASC_KEY_P8 from env var")
        app_store_connect_api_key(
          key_id: id, issuer_id: issuer,
          key_content: ENV["ASC_KEY_P8"],
          duration: 1200, in_house: false
        )
      elsif File.exist?(keyfile)
        UI.message("Using local p8 file: #{keyfile}")
        app_store_connect_api_key(
          key_id: id, issuer_id: issuer,
          key_filepath: keyfile,
          duration: 1200, in_house: false
        )
      else
        UI.user_error!("No ASC key provided (ASC_KEY_P8 env or #{keyfile})")
      end

    # increment_build_number(xcodeproj: "ios/PlateApp.xcodeproj")

    build_app(
      workspace: "ios/PlateApp.xcworkspace",
      scheme: "PlateApp",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      xcargs: %(DEVELOPMENT_TEAM=VM93Q33652 CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER="match AppStore kr.yuseongyong.plateApp" CODE_SIGN_IDENTITY="Apple Distribution" IPHONEOS_DEPLOYMENT_TARGET=16.0),
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "kr.yuseongyong.plateApp" => "match AppStore kr.yuseongyong.plateApp"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["TF_CHANGELOG"] || "CI auto build"
      # groups: ["Internal Testers"]
    )
  end
end
